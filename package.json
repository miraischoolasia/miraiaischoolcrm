{
  "name": "admin-student-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "test": "vitest run",
    "preview": "vite preview",
    "db:login": "set SUPABASE_TELEMETRY_DISABLED=1&& npx supabase login",
    "db:link": "set SUPABASE_TELEMETRY_DISABLED=1&& npx supabase link --project-ref kgagnvrmmrwaflvdvsrd",
    "db:push": "set SUPABASE_TELEMETRY_DISABLED=1&& npx supabase db push",
    "db:status": "set SUPABASE_TELEMETRY_DISABLED=1&& npx supabase migration list",
    "db:start": "set SUPABASE_TELEMETRY_DISABLED=1&& npx supabase start",
    "db:stop": "set SUPABASE_TELEMETRY_DISABLED=1&& npx supabase stop",
    "db:reset": "set SUPABASE_TELEMETRY_DISABLED=1&& npx supabase db reset",
    "db:new": "set SUPABASE_TELEMETRY_DISABLED=1&& npx supabase migration new"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.21",
    "@fullcalendar/daygrid": "^6.1.21",
    "@fullcalendar/interaction": "^6.1.21",
    "@fullcalendar/list": "^6.1.21",
    "@fullcalendar/react": "^6.1.21",
    "@fullcalendar/rrule": "^6.1.21",
    "@fullcalendar/timegrid": "^6.1.21",
    "@supabase/supabase-js": "^2.110.0",
    "@tailwindcss/vite": "^4.3.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rrule": "^2.8.1",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "supabase": "^2.109.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.9"
  }
}
